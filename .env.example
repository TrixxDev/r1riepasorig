APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

ASSET_URL=/public

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=r1riepas
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
# database — сессии в MySQL (таблица sessions), без тысяч файлов на диске
SESSION_DRIVER=database
SESSION_LIFETIME=10080
# Токен для /_migrate-sessions/{token} (удалить после переноса)
SESSION_MIGRATE_TOKEN=

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=info@r1riepas.lv
MAIL_FROM_NAME="${APP_NAME}"

# Оповещение при зависшем/очень медленном запросе (debug-06f91d.log)
SLOW_REQUEST_ALERT_EMAIL=
SLOW_REQUEST_ALERT_MS=60000
SLOW_REQUEST_ALERT_COOLDOWN_SEC=900

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Schedulebull / CSDD car info API (required for auto-fill by registration number)
SCHEDULEBULL_API_KEY=
SCHEDULEBULL_BASE_URL=https://app.schedulebull.com/api3.php

# Appointments WebSocket (optional)
# APPOINTMENT_WS_URL=https://r1riepas.lv
# Server-side: Laravel calls this URL to notify Node.js when record created. Secret stays on server.
APPOINTMENT_NOTIFY_URL=http://127.0.0.1:3001/appoApi
APPOINTMENT_SOCKET_SECRET=

# Analytics & tracking (loaded via cookie-consent after user consent)
GTM_ID=
GA4_MEASUREMENT_ID=
CLARITY_PROJECT_ID=
RECAPTCHAV3_SITEKEY=

# Marketing (Meta Pixel + CAPI server-side)
# Browser pixel: public Dataset/Pixel ID from Meta Events Manager → Datasets → Settings.
# Loads only after user accepts marketing cookies (see public/js/cookie-consent.js).
# R1 Main Pixel 2026 (dataset):
FACEBOOK_PIXEL_ID=1302511131983210
# Server-side Conversions API (secret). Enables deduplication with browser events (event_id).
META_CAPI_ACCESS_TOKEN=
# Optional: Test Events tab code while debugging CAPI only (remove in production).
META_CAPI_TEST_EVENT_CODE=

# Google Ads — client-side gtag conversion (loads after marketing cookie consent)
GOOGLE_ADS_CONVERSION_ID=
GOOGLE_ADS_CONVERSION_LABEL=
GOOGLE_ADS_BOOKING_CONVERSION_LABEL=

# Google Ads — server-side conversion API (optional, requires API access)
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_API_DEVELOPER_TOKEN=
GOOGLE_ADS_OAUTH_CLIENT_ID=
GOOGLE_ADS_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_OAUTH_REFRESH_TOKEN=
GOOGLE_ADS_PURCHASE_CONVERSION_ACTION=
GOOGLE_ADS_BOOKING_CONVERSION_ACTION=

# Product feed for Google Merchant / Meta Catalog (optional secret: ?token=...)
PRODUCT_FEED_TOKEN=
PRODUCT_FEED_BATCH=5000

# Internal mobile app (Expo) — Bearer token for /api/v1/mobile/*
MOBILE_API_TOKEN=

# Starco RSC big-tyre sync (SyncController::starco) — override defaults from config/services.php
# STARCO_LOGIN=
# STARCO_PASSWORD=
# STARCO_API_BASE=http://remote.starco.lv:8153/api.rsc/

# Fallback site season before DB row exists: 1 = summer, 2 = winter
SEASON=2

# Accrual MSSQL (local network: 192.168.0.36, public: see .env.save)
ACCRUAL_IP=192.168.0.36
ACCRUAL_PORT=1444
ACCRUAL_DATABASE=accrual
ACCRUAL_USER=sa
ACCRUAL_PASS=
# auto tries sqlsrv, then odbc. On Windows local dev use odbc after enabling pdo_odbc.
ACCRUAL_DRIVER=auto
ACCRUAL_ODBC_DRIVER="SQL Server"
# Accrual FTP import (pasutijums*.xml / prieksrekins*.xml)
ACCRUAL_USERNAME=r1_web
ACCRUAL_PASSWORD=
# Poll pzh after FTP until WEB=QuickOrder id exists (fast defaults ~1.5s max)
ACCRUAL_ORDER_VERIFY_ATTEMPTS=8
ACCRUAL_ORDER_VERIFY_INTERVAL_MS=75
ACCRUAL_ORDER_VERIFY_MAX_WAIT_MS=1500
